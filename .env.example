# ════════════════════════════════════════════════════════════════
# 🧠 HuggingMes — Hermes Agent for HuggingFace Spaces
# ════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values for local testing.
# On HF Spaces, set these as Secrets in the Space Settings.
# ════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════
# 🔑 REQUIRED: Core Configuration
# ════════════════════════════════════════════════════════════════

# [REQUIRED] Your LLM provider API key
# Supported: OpenRouter, Anthropic, OpenAI, Google, DeepSeek, etc.
# - OpenRouter: sk-or-v1-... (300+ models via single key)
# - Anthropic: sk-ant-v0-...
# - OpenAI: sk-...
# - Google: AIzaSy...
LLM_API_KEY=your_api_key_here

# [REQUIRED] LLM model ID
# Examples:
# - OpenRouter: openrouter/anthropic/claude-sonnet-4-6
# - OpenRouter: openrouter/openai/gpt-5.4
# - OpenRouter: openrouter/google/gemini-2.5-flash
# - Direct: anthropic/claude-sonnet-4-6
# - Direct: openai/gpt-5.4
# - Direct: google/gemini-2.5-flash
# - Direct: deepseek/deepseek-v3.2
LLM_MODEL=openrouter/anthropic/claude-sonnet-4-6

# [REQUIRED] Dashboard auth token (generate: openssl rand -hex 32)
GATEWAY_TOKEN=your_gateway_token_here

# ════════════════════════════════════════════════════════════════
# 🔌 OPTIONAL: API Server
# ════════════════════════════════════════════════════════════════

# API key for the OpenAI-compatible API server at /v1/
# If not set, GATEWAY_TOKEN is used instead.
HERMES_API_KEY=

# ════════════════════════════════════════════════════════════════
# 💬 OPTIONAL: Messaging Platforms
# ════════════════════════════════════════════════════════════════

# ── Telegram ──
# Create a bot via @BotFather: https://t.me/botfather
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_ALLOWED_USERS=user_id1,user_id2

# ── Discord ──
# Create an app: https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=your_bot_token
# DISCORD_APP_ID=your_app_id

# ── Slack ──
# Create an app: https://api.slack.com/apps
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# ════════════════════════════════════════════════════════════════
# 💾 OPTIONAL: Workspace Backup
# ════════════════════════════════════════════════════════════════

# HF_TOKEN — HuggingFace token for workspace backup
# Get at: https://huggingface.co/settings/tokens
# HF_TOKEN=

# ════════════════════════════════════════════════════════════════
# 🔧 OPTIONAL: Additional API Keys
# ════════════════════════════════════════════════════════════════

# OpenAI API key (for OpenAI models or fallback)
# OPENAI_API_KEY=sk-...

# Anthropic API key (for Claude models)
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini API key
# GEMINI_API_KEY=AIza...

# DeepSeek API key
# DEEPSEEK_API_KEY=sk-...

# Grok/xAI API key
# XAI_API_KEY=

# Mistral API key
# MISTRAL_API_KEY=

# Together AI API key
# TOGETHER_API_KEY=

# Groq API key (free tier — used for Whisper STT in voice mode)
# GROQ_API_KEY=

# ════════════════════════════════════════════════════════════════
# ⚙️ OPTIONAL: Advanced Configuration
# ════════════════════════════════════════════════════════════════

# Hermes data directory
# HERMES_HOME=/home/hermes/.hermes

# DEV_MODE — set to true to enable JupyterLab terminal
# DEV_MODE=false

# Ports (override if needed)
# PORT=7860
# GATEWAY_PORT=8642
# DASHBOARD_PORT=9119
# JUPYTER_PORT=8888

# Log level: debug, info, warn, error
# HERMES_LOG_LEVEL=info
