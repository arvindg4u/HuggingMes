# HuggingMes — HF Space Secrets Template
# Set these in HF Space Settings → Secrets (never commit real values)

# ── Required: Core (3) ──
LLM_MODEL=opencode-free/deepseek-v4-flash-free
LLM_API_KEY=your_opencode_api_key
GATEWAY_TOKEN=your_gateway_token

# ── Telegram (optional) ──
# TELEGRAM_BOT_TOKEN=your_bot_token
# TELEGRAM_ALLOWED_USERS=user_id1,user_id2

# ── HF Dataset Backup (optional) ──
# HF_TOKEN=hf_your_token
# HF_USERNAME=your_hf_username
# BACKUP_DATASET_NAME=huggingmes-backup

# ── JupyterLab terminal ──
DEV_MODE=true
API_SERVER_PORT=8642
